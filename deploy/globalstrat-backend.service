[Unit]
Description=GlobalStrat Django Backend (Gunicorn)
After=network.target postgresql.service

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/projects/globalstrat/backend
Environment=GLOBALSTRAT_ENV=production
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/gunicorn -c gunicorn.conf.py globalstrat.wsgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
